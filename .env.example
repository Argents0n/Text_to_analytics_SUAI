# Provider: "openrouter" (default) or "ollama"
T2A_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys).
# openrouter/free = meta-router over free models; dodges per-model rate limits.
# For reproducible eval pin a specific coder model, e.g. qwen/qwen3-coder:free.
OPENROUTER_API_KEY=
T2A_MODEL=openrouter/free

# Ollama fallback (local). Requires `ollama serve` + `ollama pull qwen2.5-coder:7b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
